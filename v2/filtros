// Este bloque genera los MSN del 0135 al 0220 automáticamente al cargar la página
  document.addEventListener("DOMContentLoaded", function() {
    const msnDatalist = document.getElementById("lista-msn");
    for (let i = 135; i <= 220; i++) {
      let option = document.createElement("option");
      // Le añadimos el "0" delante para que sea formato 0135, 0136...
      option.value = "0" + i; 
      msnDatalist.appendChild(option);
    }
  });
  
