{"files":[{"id":"afb31260-9af8-4d90-a9c2-99d26c374b6e","name":"appsscript","type":"json","source":"{\n  \"timeZone\": \"Europe/Berlin\",\n  \"dependencies\": {},\n  \"exceptionLogging\": \"STACKDRIVER\",\n  \"runtimeVersion\": \"V8\",\n  \"webapp\": {\n    \"executeAs\": \"USER_ACCESSING\",\n    \"access\": \"DOMAIN\"\n  }\n}"},{"id":"ced06827-dce3-41c3-ac93-697e10aa2571","name":"Code","type":"server_js","source":"function doGet() {\n  return HtmlService.createHtmlOutputFromFile(\u0027Index\u0027)\n      .setTitle(\u0027Lessons Learnt App\u0027)\n      .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);\n}\nfunction guardarDatos(data, fileData) {\n  try {\n    const SHEET_ID \u003d \u00271C-tLy2n9-W5RVgdcF6P6BNmkBhlBY8ePstOSCFJKNF0\u0027; \n    const FOLDER_ID \u003d \u00271_1rdyGfWbCGxIoOPQh9itc4bz7mo2HZY\u0027; \n    const TEMPLATE_ID \u003d \u00271IUSitAQPApYRZO1tXRpT0UyOM2NE5rCsQISmVtIKyIs\u0027; // \u003c--- PEGA AQUÍ EL ID DE TU SLIDE PLANTILLA\n\n    const ss \u003d SpreadsheetApp.openById(SHEET_ID);\n    const sheet \u003d ss.getSheets()[0];\n    const folder \u003d DriveApp.getFolderById(FOLDER_ID);\n\n    // 1. CREAR COPIA DE LA PLANTILLA\n    const nombrePPT \u003d \"Lesson_Learnt_\" + (data.title || \"Sin_Titulo\") + \"_\" + new Date().getTime();\n    const copiaArchivo \u003d DriveApp.getFileById(TEMPLATE_ID).makeCopy(nombrePPT, folder);\n    const presentation \u003d SlidesApp.openById(copiaArchivo.getId());\n    const slide \u003d presentation.getSlides()[0];\n\n    // 2. REEMPLAZAR TEXTOS (Busca {{etiqueta}} y pone el valor)\n    slide.replaceAllText(\u0027{{title}}\u0027, data.title || \"\");\n    slide.replaceAllText(\u0027{{sta}}\u0027, data.sta || \"\");\n    slide.replaceAllText(\u0027{{msn}}\u0027, data.msn || \"\");\n    slide.replaceAllText(\u0027{{author}}\u0027, data.author || \"\");\n    slide.replaceAllText(\u0027{{Reference}}\u0027, data.Reference || \"\");\n    slide.replaceAllText(\u0027{{description}}\u0027, data.description || \"\");\n    slide.replaceAllText(\u0027{{solution}}\u0027, data.solution || \"\");\n    slide.replaceAllText(\u0027{{do}}\u0027, data.do || \"\");\n    slide.replaceAllText(\u0027{{dont}}\u0027, data.dont || \"\");\n    slide.replaceAllText(\u0027{{impactedProcess}}\u0027, data.impactedProcess || \"\");\n    slide.replaceAllText(\u0027{{actions}}\u0027, data.actions || \"\");\n    slide.replaceAllText(\u0027{{date}}\u0027, new Date().toLocaleDateString());\n\n\n    // 3. INSERTAR IMAGEN\n    if (fileData \u0026\u0026 fileData.data) {\n      const bytes \u003d Utilities.base64Decode(fileData.data);\n      const blob \u003d Utilities.newBlob(bytes, fileData.type, fileData.name);\n      \n//Buscamos la forma\nconst shapes \u003d slide.getShapes();\nlet marcadorEncontrado \u003d false;\n\nfor (let i\u003d0; i \u003c shapes.length; i++){\n  const shape \u003d shapes [i];\n  const text \u003d shape.getText().asString().trim();\n\n  //Si la forma contiene nuestra etiqueta de la imagen\n  if (text \u003d\u003d\u003d \u0027{{Image}}\u0027) {\n    //obtenemos posición y dimensiones de la forma\n    const left \u003d shape.getLeft();\n    const top \u003d shape.getTop();\n    const width \u003d shape.getWidth();\n    const height \u003d shape.getHeight();\n\n    //Insertamos la imagen escalada al tamaño de la forma\n    slide.insertImage(blob, left, top, width,height);\n\n    //borramos la forma original para que no se vea el texto  {{Image}}\n    shape.remove();\n    marcadorEncontrado \u003d true;\n    break;\n  }\n}\n\n//Si no encontramos el marcador, podemos inserta por defecto en una esquina\nif (!marcadorEncontrado) {\n  console.warn (\"No se encontró el marcador {{Image}} en la plantilla\");\n}\n    }\n\n    presentation.saveAndClose();\n    const finalUrl \u003d copiaArchivo.getUrl();\n\n    // 4. REGISTRAR EN EXCEL\n    const row \u003d [\n      data.sta || \"\", data.msn || \"\", data.author || \"\", data.Reference || \"\",\n      new Date(), data.title || \"\", data.description || \"\", data.solution || \"\",\n      data.do || \"\", data.dont || \"\", data.impactedProcess || \"\", data.actions || \"\",\n      finalUrl\n    ];\n\n    sheet.appendRow(row);\n    return \"✅ Guardado. Se ha creado una ficha idéntica a la plantilla.\";\n\n  } catch (e) {\n    throw new Error(\"Error: \" + e.message);\n  }\n}\n\n"},{"id":"64140bd2-1690-4037-8017-fd9a41708c58","name":"Index","type":"html","source":"\u003c!DOCTYPE html\u003e\n\u003chtml\u003e\n\u003chead\u003e\n  \u003cbase target\u003d\"_top\"\u003e\n  \u003cstyle\u003e\n    :root {\n      --blue-dark: #002060;\n      --blue-light: #BDD7EE;\n      --gray-light: #E2E2E2;\n    }\n    \n    body { \n      font-family: \u0027Segoe UI\u0027, Tahoma, Geneva, Verdana, sans-serif; \n      margin: 20px; \n      background-color: #92D6E6; \n    }\n    .form-container { \n      max-width: 900px; \n      margin: auto; \n      background: white; \n      border: 2px solid var(--blue-dark); \n      box-shadow: 0 4px 8px rgba(0,0,0,0.1); \n    }\n    \n    /* Header Table Style */\n    .grid-header { display: grid; grid-template-columns: 15% 15% 15% 20% 15% 20%; border-bottom: 2px solid var(--blue-dark); }\n    .header-cell { border: 0.5px solid var(--blue-dark); padding: 8px; text-align: center; font-weight: bold; }\n    .label-blue { background-color: var(--blue-light); }\n    \n    /* Form Sections */\n    .section { border-bottom: 1px solid var(--blue-dark); padding: 0; }\n    .section-label { \n      background: var(--blue-light); \n      padding: 5px 10px; \n      font-weight: bold; \n      text-decoration: underline; \n      display: block; \n      border-bottom: 1px solid var(--blue-dark); \n    }\n    .content-padding { padding: 10px; }\n    \n    /* Layout for Solution and Recommendations */\n    .flex-row { display: flex; border-bottom: 1px solid var(--blue-dark); }\n    .flex-col { flex: 1; border-right: 1px solid var(--blue-dark); }\n    .flex-col:last-child { border-right: none; }\n\n    /* Inputs */\n    input[type\u003d\"text\"], textarea { width: 100%; border: 1px solid #ccc; box-sizing: border-box; padding: 8px; font-size: 14px; }\n    textarea { height: 80px; resize: vertical; }\n    .auto-gen { background: #d9d9d9; color: #666; font-style: italic; font-size: 0.8em; }\n\n    /* Buttons */\n    .footer { padding: 20px; text-align: center; background: #f9f9f9; }\n    #btn-submit { \n      background: var(--blue-dark); \n      color: white; \n      padding: 12px 30px; \n      border: none; \n      border-radius: 4px; \n      cursor: pointer; \n      font-size: 16px; \n      font-weight: bold; \n    }\n    #btn-submit:disabled { background: #666; }\n    \n    /* NUEVOS ESTILOS DE IMAGEN */\n    .img-upload-box { \n      background: #7f7f7f; \n      color: white; \n      padding: 10px; \n      text-align: center; \n      min-height: 200px; \n      display: flex; \n      flex-direction: column; \n      justify-content: center;\n      align-items: center;\n    }\n    #previewImg { \n      max-width: 90%; \n      max-height: 180px; \n      display: none; \n      border: 2px solid #fff;\n      margin-bottom: 10px;\n      object-fit: contain;\n    }\n    #fileInput { font-size: 12px; width: 90%; }\n  \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n\n\u003cdiv class\u003d\"form-container\"\u003e\n  \u003cform id\u003d\"lessonForm\"\u003e\n    \u003cdiv class\u003d\"grid-header\"\u003e\n      \u003cdiv class\u003d\"header-cell label-blue\"\u003eSTA\u003c/div\u003e\n      \u003cdiv class\u003d\"header-cell\"\u003e\u003cinput type\u003d\"text\" name\u003d\"sta\" placeholder\u003d\"...\"\u003e\u003c/div\u003e\n      \u003cdiv class\u003d\"header-cell label-blue\"\u003eMSN\u003c/div\u003e\n      \u003cdiv class\u003d\"header-cell\"\u003e\u003cinput type\u003d\"text\" name\u003d\"msn\" placeholder\u003d\"...\"\u003e\u003c/div\u003e\n      \u003cdiv class\u003d\"header-cell label-blue\"\u003eAuthor\u003c/div\u003e\n      \u003cdiv class\u003d\"header-cell\"\u003e\u003cinput type\u003d\"text\" name\u003d\"author\" placeholder\u003d\"...\"\u003e\u003c/div\u003e\n    \u003c/div\u003e\n    \n    \u003cdiv class\u003d\"grid-header\"\u003e\n      \u003cdiv class\u003d\"header-cell label-blue\"\u003eTITLE\u003c/div\u003e\n      \u003cdiv class\u003d\"header-cell\" style\u003d\"grid-column: span 3;\"\u003e\u003cinput type\u003d\"text\" name\u003d\"title\"\u003e\u003c/div\u003e\n      \u003cdiv class\u003d\"header-cell label-blue\"\u003eReference\u003c/div\u003e      \n      \u003cdiv class\u003d\"header-cell\"\u003e\u003cinput type\u003d\"text\" name\u003d\"Reference\" placeholder\u003d\"...\"\u003e\u003c/div\u003e\n      \u003cdiv class\u003d\"header-cell label-blue\"\u003eDate\u003c/div\u003e\n      \u003cdiv class\u003d\"header-cell auto-gen\"\u003eAuto-generado\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv class\u003d\"section\"\u003e\n      \u003cspan class\u003d\"section-label\"\u003eDescription\u003c/span\u003e\n      \u003cdiv class\u003d\"content-padding\"\u003e\u003ctextarea name\u003d\"description\"\u003e\u003c/textarea\u003e\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv class\u003d\"flex-row\"\u003e\n      \u003cdiv class\u003d\"flex-col\"\u003e\n        \u003cspan class\u003d\"section-label\"\u003eSolution:\u003c/span\u003e\n        \u003cdiv class\u003d\"content-padding\"\u003e\u003ctextarea name\u003d\"solution\"\u003e\u003c/textarea\u003e\u003c/div\u003e\n      \u003c/div\u003e\n      \u003cdiv class\u003d\"flex-col\"\u003e\n        \u003cspan class\u003d\"section-label\"\u003eRecommendations:\u003c/span\u003e\n        \u003cdiv class\u003d\"content-padding\"\u003e\n          \u003cstrong\u003eDo:\u003c/strong\u003e \u003cinput type\u003d\"text\" name\u003d\"do\" style\u003d\"margin-bottom:10px\"\u003e\n          \u003cstrong\u003eDon\u0027t:\u003c/strong\u003e \u003cinput type\u003d\"text\" name\u003d\"dont\"\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv class\u003d\"flex-row\"\u003e\n      \u003cdiv class\u003d\"flex-col\"\u003e\n        \u003cspan class\u003d\"section-label\"\u003eImpacted Process (if any):\u003c/span\u003e\n        \u003cdiv class\u003d\"content-padding\"\u003e\u003cinput type\u003d\"text\" name\u003d\"impactedProcess\"\u003e\u003c/div\u003e\n        \u003cspan class\u003d\"section-label\"\u003eActions to be performed:\u003c/span\u003e\n        \u003cdiv class\u003d\"content-padding\"\u003e\u003ctextarea name\u003d\"actions\"\u003e\u003c/textarea\u003e\u003c/div\u003e\n      \u003c/div\u003e\n      \n      \u003cdiv class\u003d\"flex-col img-upload-box\"\u003e\n        \u003cstrong\u003eIMAGE / SKETCH\u003c/strong\u003e\n        \u003cimg id\u003d\"previewImg\" src\u003d\"\"\u003e \n        \u003cp id\u003d\"txtGuide\"\u003eINSERT IMAGE INTO REPOSITORY\u003c/p\u003e\n        \u003cinput type\u003d\"file\" id\u003d\"fileInput\" accept\u003d\"image/*\" onchange\u003d\"fijarImagen(this)\"\u003e\n      \u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv class\u003d\"footer\"\u003e\n      \u003cbutton type\u003d\"button\" id\u003d\"btn-submit\" onclick\u003d\"procesarFormulario()\"\u003eSAVE LESSON LEARNT\u003c/button\u003e\n    \u003c/div\u003e\n  \u003c/form\u003e\n\u003c/div\u003e\n\n\u003cscript\u003e\n  // Función para dejar la imagen fija en el cuadro tras seleccionarla\n  function fijarImagen(input) {\n    const preview \u003d document.getElementById(\u0027previewImg\u0027);\n    const guide \u003d document.getElementById(\u0027txtGuide\u0027);\n    \n    if (input.files \u0026\u0026 input.files[0]) {\n      const reader \u003d new FileReader();\n      reader.onload \u003d function(e) {\n        preview.src \u003d e.target.result;\n        preview.style.display \u003d \u0027block\u0027;\n        guide.style.display \u003d \u0027none\u0027;\n      }\n      reader.readAsDataURL(input.files[0]);\n    }\n  }\n\n  function procesarFormulario() {\n    const btn \u003d document.getElementById(\u0027btn-submit\u0027);\n    const form \u003d document.getElementById(\u0027lessonForm\u0027);\n    const fileInput \u003d document.getElementById(\u0027fileInput\u0027).files[0];\n\n    // Desactivar botón y cambiar texto\n    btn.disabled \u003d true;\n    btn.innerText \u003d \"⏳ Generando documento idéntico...\";\n\n    const formData \u003d Object.fromEntries(new FormData(form).entries());\n\n    if (fileInput) {\n      const reader \u003d new FileReader();\n      reader.onload \u003d function(e) {\n        const fileData \u003d {\n          data: e.target.result.split(\u0027,\u0027)[1],\n          type: fileInput.type,\n          name: \"IMG_\" + Date.now() + \"_\" + fileInput.name.replace(/[^a-z0-9.]/gi, \u0027_\u0027)\n        };\n        enviarServidor(formData, fileData);\n      };\n      reader.onerror \u003d function() {\n        alert(\"Error al leer la imagen local.\");\n        resetBoton();\n      };\n      reader.readAsDataURL(fileInput);\n    } else {\n      enviarServidor(formData, null);\n    }\n  }\n\n  function enviarServidor(data, file) {\n    google.script.run\n      .withSuccessHandler(res \u003d\u003e {\n        alert(res);\n        document.getElementById(\u0027lessonForm\u0027).reset();\n        \n        // Resetear visualización de imagen\n        document.getElementById(\u0027previewImg\u0027).style.display \u003d \u0027none\u0027;\n        document.getElementById(\u0027previewImg\u0027).src \u003d \"\";\n        document.getElementById(\u0027txtGuide\u0027).style.display \u003d \u0027block\u0027;\n        \n        resetBoton();\n      })\n      .withFailureHandler(err \u003d\u003e {\n        alert(\"Error en el proceso: \" + err.message);\n        resetBoton();\n      })\n      .guardarDatos(data, file);\n  }\n\n  function resetBoton() {\n    const btn \u003d document.getElementById(\u0027btn-submit\u0027);\n    btn.disabled \u003d false;\n    btn.innerText \u003d \"SAVE LESSON LEARNT\";\n  }\n\u003c/script\u003e\n\n\u003c/body\u003e\n\u003c/html\u003e"}]}