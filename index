<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <style>
    :root {
      --blue-dark: #002060;
      --blue-light: #BDD7EE;
      --gray-light: #E2E2E2;
    }
    body { 
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
      margin: 20px; 
      background-color: #92D6E6; 
    }
    .form-container { 
      max-width: 900px; 
      margin: auto; 
      background: white; 
      border: 2px solid var(--blue-dark); 
      box-shadow: 0 4px 8px rgba(0,0,0,0.1); 
    }
    
    /* Header Table Style */
    .grid-header { display: grid; grid-template-columns: 15% 15% 15% 20% 15% 20%; border-bottom: 2px solid var(--blue-dark); }
    .header-cell { border: 0.5px solid var(--blue-dark); padding: 8px; text-align: center; font-weight: bold; }
    .label-blue { background-color: var(--blue-light); }
    
    /* Form Sections */
    .section { border-bottom: 1px solid var(--blue-dark); padding: 0; }
    .section-label { 
      background: var(--blue-light); 
      padding: 5px 10px; 
      font-weight: bold; 
      text-decoration: underline; 
      display: block; 
      border-bottom: 1px solid var(--blue-dark); 
    }
    .content-padding { padding: 10px; }
    
    /* Layout for Solution and Recommendations */
    .flex-row { display: flex; border-bottom: 1px solid var(--blue-dark); }
    .flex-col { flex: 1; border-right: 1px solid var(--blue-dark); }
    .flex-col:last-child { border-right: none; }

    /* Inputs */
    input[type="text"], textarea { width: 100%; border: 1px solid #ccc; box-sizing: border-box; padding: 8px; font-size: 14px; }
    textarea { height: 80px; resize: vertical; }
    .auto-gen { background: #d9d9d9; color: #666; font-style: italic; font-size: 0.8em; }

    /* Buttons */
    .footer { padding: 20px; text-align: center; background: #f9f9f9; }
    #btn-submit { 
      background: var(--blue-dark); 
      color: white; 
      padding: 12px 30px; 
      border: none; 
      border-radius: 4px; 
      cursor: pointer; 
      font-size: 16px; 
      font-weight: bold; 
    }
    #btn-submit:disabled { background: #666; }
    
    /* NUEVOS ESTILOS DE IMAGEN */
    .img-upload-box { 
      background: #7f7f7f; 
      color: white; 
      padding: 10px; 
      text-align: center; 
      min-height: 200px; 
      display: flex; 
      flex-direction: column; 
      justify-content: center;
      align-items: center;
    }
    #previewImg { 
      max-width: 90%; 
      max-height: 180px; 
      display: none; 
      border: 2px solid #fff;
      margin-bottom: 10px;
      object-fit: contain;
    }
    #fileInput { font-size: 12px; width: 90%; }
  </style>
</head>
<body>

<div class="form-container">
  <form id="lessonForm">
    <div class="grid-header">
      <div class="header-cell label-blue">STA</div>
      <div class="header-cell"><input type="text" name="sta" placeholder="..."></div>
      <div class="header-cell label-blue">MSN</div>
      <div class="header-cell"><input type="text" name="msn" placeholder="..."></div>
      <div class="header-cell label-blue">Author</div>
      <div class="header-cell"><input type="text" name="author" placeholder="..."></div>
    </div>
    
    <div class="grid-header">
      <div class="header-cell label-blue">TITLE</div>
      <div class="header-cell" style="grid-column: span 3;"><input type="text" name="title"></div>
      <div class="header-cell label-blue">Reference</div>      
      <div class="header-cell"><input type="text" name="Reference" placeholder="..."></div>
      <div class="header-cell label-blue">Date</div>
      <div class="header-cell auto-gen">Auto-generado</div>
    </div>

    <div class="section">
      <span class="section-label">Description</span>
      <div class="content-padding"><textarea name="description"></textarea></div>
    </div>

    <div class="flex-row">
      <div class="flex-col">
        <span class="section-label">Solution:</span>
        <div class="content-padding"><textarea name="solution"></textarea></div>
      </div>
      <div class="flex-col">
        <span class="section-label">Recommendations:</span>
        <div class="content-padding">
          <strong>Do:</strong> <input type="text" name="do" style="margin-bottom:10px">
          <strong>Don't:</strong> <input type="text" name="dont">
        </div>
      </div>
    </div>

    <div class="flex-row">
      <div class="flex-col">
        <span class="section-label">Impacted Process (if any):</span>
        <div class="content-padding"><input type="text" name="impactedProcess"></div>
        <span class="section-label">Actions to be performed:</span>
        <div class="content-padding"><textarea name="actions"></textarea></div>
      </div>
      
      <div class="flex-col img-upload-box">
        <strong>IMAGE / SKETCH</strong>
        <img id="previewImg" src=""> 
        <p id="txtGuide">INSERT IMAGE INTO REPOSITORY</p>
        <input type="file" id="fileInput" accept="image/*" onchange="fijarImagen(this)">
      </div>
    </div>

    <div class="footer">
      <button type="button" id="btn-submit" onclick="procesarFormulario()">SAVE LESSON LEARNT</button>
    </div>
  </form>
</div>

<script>
  // Función para dejar la imagen fija en el cuadro tras seleccionarla
  function fijarImagen(input) {
    const preview = document.getElementById('previewImg');
    const guide = document.getElementById('txtGuide');
    
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = function(e) {
        preview.src = e.target.result;
        preview.style.display = 'block';
        guide.style.display = 'none';
      }
      reader.readAsDataURL(input.files[0]);
    }
  }

  function procesarFormulario() {
    const btn = document.getElementById('btn-submit');
    const form = document.getElementById('lessonForm');
    const fileInput = document.getElementById('fileInput').files[0];

    // Desactivar botón y cambiar texto
    btn.disabled = true;
    btn.innerText = "⏳ Generando documento idéntico...";

    const formData = Object.fromEntries(new FormData(form).entries());

    if (fileInput) {
      const reader = new FileReader();
      reader.onload = function(e) {
        const fileData = {
          data: e.target.result.split(',')[1],
          type: fileInput.type,
          name: "IMG_" + Date.now() + "_" + fileInput.name.replace(/[^a-z0-9.]/gi, '_')
        };
        enviarServidor(formData, fileData);
      };
      reader.onerror = function() {
        alert("Error al leer la imagen local.");
        resetBoton();
      };
      reader.readAsDataURL(fileInput);
    } else {
      enviarServidor(formData, null);
    }
  }

  function enviarServidor(data, file) {
    google.script.run
      .withSuccessHandler(res => {
        alert(res);
        document.getElementById('lessonForm').reset();
        
        // Resetear visualización de imagen
        document.getElementById('previewImg').style.display = 'none';
        document.getElementById('previewImg').src = "";
        document.getElementById('txtGuide').style.display = 'block';
        
        resetBoton();
      })
      .withFailureHandler(err => {
        alert("Error en el proceso: " + err.message);
        resetBoton();
      })
      .guardarDatos(data, file);
  }

  function resetBoton() {
    const btn = document.getElementById('btn-submit');
    btn.disabled = false;
    btn.innerText = "SAVE LESSON LEARNT";
  }
</script>

</body>
</html>
